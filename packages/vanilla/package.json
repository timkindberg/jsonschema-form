{
  "name": "@jsonschema-form/vanilla",
  "version": "0.0.0",
  "description": "Framework-agnostic (no UI framework) HTML renderer for JSON Schema forms — the second-implementation probe and conformance oracle",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "echo 'Build script not yet configured'",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "json-schema",
    "forms",
    "html",
    "vanilla"
  ],
  "author": "Tim Kindberg",
  "license": "MIT",
  "peerDependencies": {
    "@jsonschema-form/core": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^4.0.9"
  }
}
