{
  "name": "@jsonschema-form/input-jsonschema",
  "version": "0.0.0",
  "description": "JSON Schema front-end for @jsonschema-form/core — compiles JSON Schema into the neutral form tree (ADR 033)",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "echo 'Build script not yet configured'",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "json-schema",
    "forms"
  ],
  "author": "Tim Kindberg",
  "license": "MIT",
  "peerDependencies": {
    "@jsonschema-form/core": "*"
  },
  "dependencies": {
    "json-schema-typed": "^8.0.1"
  },
  "devDependencies": {
    "@jsonschema-form/core": "*",
    "typescript": "^5.3.3",
    "vitest": "^4.0.9"
  }
}
