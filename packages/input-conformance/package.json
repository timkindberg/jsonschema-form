{
  "name": "@jsonschema-form/input-conformance",
  "version": "0.0.0",
  "description": "The shared input-conformance oracle — expected neutral trees every @jsonschema-form/input-* front-end must produce for equivalent schemas (ADR 033/034). Test-only; imports nothing from any input-* package.",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.spec.ts",
    "!**/*TestUtils.ts"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap --tsconfig ../../tsconfig.tsup.json",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "conformance",
    "forms"
  ],
  "author": "Tim Kindberg",
  "license": "MIT",
  "peerDependencies": {
    "@jsonschema-form/core": "*",
    "vitest": "^4"
  },
  "devDependencies": {
    "@jsonschema-form/core": "*",
    "typescript": "^5.3.3",
    "vitest": "^4.0.9"
  }
}
