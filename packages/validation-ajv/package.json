{
  "name": "@jsonschema-form/validation-ajv",
  "version": "0.0.0",
  "description": "AJV validation adapter for JSON Schema forms",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.spec.ts",
    "!**/*TestUtils.ts"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap --tsconfig ../../tsconfig.tsup.json",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "json-schema",
    "validation",
    "ajv"
  ],
  "author": "Tim Kindberg",
  "license": "MIT",
  "peerDependencies": {
    "@jsonschema-form/core": "*",
    "@jsonschema-form/input-jsonschema": "*",
    "ajv": "^8.0.0"
  },
  "devDependencies": {
    "@jsonschema-form/core": "*",
    "@jsonschema-form/input-jsonschema": "*",
    "@jsonschema-form/validation-contract": "*",
    "ajv": "^8.17.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.9"
  },
  "dependencies": {
    "ajv-formats": "^3.0.1"
  }
}
