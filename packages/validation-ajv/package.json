{
  "name": "@jsonschema-form/validation-ajv",
  "version": "0.0.0",
  "description": "AJV validation adapter for JSON Schema forms",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "echo 'Build script not yet configured'",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "json-schema",
    "validation",
    "ajv"
  ],
  "author": "Tim Kindberg",
  "license": "MIT",
  "peerDependencies": {
    "@jsonschema-form/core": "*",
    "@jsonschema-form/input-jsonschema": "*",
    "ajv": "^8.0.0"
  },
  "devDependencies": {
    "@jsonschema-form/core": "*",
    "@jsonschema-form/input-jsonschema": "*",
    "@jsonschema-form/validation-contract": "*",
    "ajv": "^8.17.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.9"
  },
  "dependencies": {
    "ajv-formats": "^3.0.1"
  }
}
