{
  "name": "@jsonschema-form/input-zod",
  "version": "0.0.0",
  "description": "Zod front-end for @jsonschema-form/core — compiles a Zod schema into the neutral form tree by direct introspection (ADR 034)",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.spec.ts",
    "!**/*TestUtils.ts"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap --tsconfig ../../tsconfig.tsup.json",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "zod",
    "forms"
  ],
  "author": "Tim Kindberg",
  "license": "MIT",
  "peerDependencies": {
    "@jsonschema-form/core": "*",
    "zod": "^4"
  },
  "devDependencies": {
    "@jsonschema-form/core": "*",
    "@jsonschema-form/input-conformance": "*",
    "typescript": "^5.3.3",
    "vitest": "^4.0.9",
    "zod": "^4.0.0"
  }
}
