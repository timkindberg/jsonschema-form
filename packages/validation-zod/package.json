{
  "name": "@jsonschema-form/validation-zod",
  "version": "0.0.0",
  "description": "Zod validation adapter for JSON Schema forms",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "echo 'Build script not yet configured'",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "json-schema",
    "validation",
    "zod"
  ],
  "author": "Tim Kindberg",
  "license": "MIT",
  "peerDependencies": {
    "@jsonschema-form/core": "*",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@jsonschema-form/core": "*",
    "@jsonschema-form/validation-ajv": "*",
    "typescript": "^5.3.3",
    "vitest": "^4.0.9"
  }
}
