{
  "name": "@formframe/renderer-react",
  "version": "0.0.0",
  "description": "React adapter for FormFrame trees from any schema front-end",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.spec.ts",
    "!**/*TestUtils.ts"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap --tsconfig ../../tsconfig.tsup.json",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "json-schema",
    "forms",
    "react"
  ],
  "author": "Tim Kindberg",
  "license": "MIT",
  "peerDependencies": {
    "@formframe/core": "*",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@formframe/input-jsonschema": "*",
    "@formframe/input-zod": "*",
    "@formframe/validation-ajv": "*",
    "@formframe/validation-zod": "*",
    "@formframe/renderer-vanilla": "*",
    "@types/react": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "playwright": "^1.49.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.14",
    "vitest-browser-react": "^2.0.2",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@vitest/browser-playwright": "^4.0.14"
  }
}
