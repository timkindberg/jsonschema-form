{
  "name": "@jsonschema-form/react",
  "version": "0.0.0",
  "description": "React adapter for JSON Schema forms",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "echo 'Build script not yet configured'",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "json-schema",
    "forms",
    "react"
  ],
  "author": "Tim Kindberg",
  "license": "MIT",
  "peerDependencies": {
    "@jsonschema-form/core": "*",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "playwright": "^1.49.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.14",
    "vitest-browser-react": "^2.0.2"
  },
  "dependencies": {
    "@vitest/browser-playwright": "^4.0.14"
  }
}
