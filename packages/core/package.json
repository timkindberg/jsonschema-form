{
  "name": "@jsonschema-form/core",
  "version": "0.0.0",
  "description": "Headless core logic for JSON Schema form generation",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "echo 'Build script not yet configured'",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "json-schema",
    "forms",
    "headless",
    "core"
  ],
  "author": "Tim Kindberg",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^4.0.9"
  },
  "dependencies": {
    "json-schema-typed": "^8.0.1"
  }
}
